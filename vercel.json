{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.8.0"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/includes/.*",
      "status": 403
    },
    {
      "src": "^/errors/.*",
      "status": 403
    },
    {
      "handle": "filesystem"
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "/(.*)",
      "dest": "/errors/404.php"
    },
    {
      "status": 403,
      "src": "/(.*)",
      "dest": "/errors/403.php"
    },
    {
      "status": 500,
      "src": "/(.*)",
      "dest": "/errors/500.php"
    }
  ]
}
